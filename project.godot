; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Dost GameJam"
run/main_scene="uid://dm1hwrj3l0df6"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

GameEnums="*res://script/globals/game_enums.gd"
Talo="*uid://bpmdn8oc34pg7"
DialogueManager="*uid://c3rodes2l3gxb"
BattleEvents="*uid://d3ojlq3odosqy"
ItemDb="*res://script/globals/itemsDB.gd"
PlayerProfile="*res://script/globals/player_profile.gd"
PlayerStats="*res://script/globals/player_stats.gd"
PlayerInventory="*res://script/globals/player_inventory.gd"
SaveManager="*res://script/globals/save_manager.gd"
ManaManager="*uid://bq06oex8xu486"
ShopManager="*res://script/globals/shop_manager.gd"
UIManager="*res://script/globals/ui_manager.gd"
AudioManager="*uid://d3im66uqs6wge"
SceneTransition="*uid://c13y30hlw4iug"
StoryManager="*res://script/globals/story_manager.gd"
CardRegistry="*res://script/globals/card_registry.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/mode=3
window/stretch/mode="canvas_items"
window/vsync/vsync_mode=0

[editor_plugins]

enabled=PackedStringArray("res://addons/dialogue_manager/plugin.cfg", "res://addons/talo/plugin.cfg")

[global_group]

cards=""
ui_elements=""

[internationalization]

locale/translations_pot_files=PackedStringArray("res://script/story/dialogue/chapter_one.dialogue", "res://script/story/dialogue/chapter_two.dialogue", "res://script/story/dialogue/chapter_three.dialogue")

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

textures/canvas_textures/default_texture_filter=0
rendering_device/driver.windows="d3d12"
